#!/system/bin/sh

# Ensure running as root
if [ "$(id -u)" -ne 0 ]; then
  echo "[!] Error: This command requires root access."
  echo "    Use 'su -c miyabi <arg>' or enter root shell ('su') first."
  exit 1
fi

# Validate arguments
if [ -z "$1" ] || [ "$1" != "on" -a "$1" != "off" -a "$1" != "status" ] 2>/dev/null; then
  echo "============================================="
  echo "      🌸 GMS Breaker Miyabi Core CLI 🌸      "
  echo "============================================="
  echo "Usage:"
  echo "  miyabi on      - Enable GMS Breaker (Freeze GMS)"
  echo "  miyabi off     - Disable GMS Breaker (Unfreeze GMS)"
  echo "  miyabi status  - Check current isolation status"
  echo "============================================="
  exit 0
fi

FLAG_FILE="/data/adb/miyabi_disabled"

case "$1" in
  on)
    if [ -f "$FLAG_FILE" ]; then
      rm -f "$FLAG_FILE"
      echo "[+] GMS Breaker Miyabi Core: ENABLED (GMS will be frozen shortly)"
    else
      echo "[!] GMS Breaker is already enabled."
    fi
    ;;
  off)
    if [ ! -f "$FLAG_FILE" ]; then
      touch "$FLAG_FILE"
      echo "[+] GMS Breaker Miyabi Core: TEMPORARILY DISABLED (GMS active)"
    else
      echo "[!] GMS Breaker is already disabled."
    fi
    ;;
  status)
    echo "============================================="
    echo "            Miyabi Core Status               "
    echo "============================================="
    if [ -f "$FLAG_FILE" ]; then
      echo "Breaker Status : TEMPORARILY DISABLED (GMS Active)"
    else
      echo "Breaker Status : ENABLED (GMS Isolated)"
    fi
    
    # Check GMS process status (handles SIGSTOP states)
    GMS_PIDS=$(pgrep -f com.google.android.gms)
    if [ -z "$GMS_PIDS" ]; then
      echo "GMS Processes  : Suspended/Stopped"
    else
      active_gms=0
      for pid in $GMS_PIDS; do
        if [ -f "/proc/$pid/stat" ]; then
          read r_pid r_comm r_state r_rest < "/proc/$pid/stat"
          if [ "$r_state" != "T" ]; then
            active_gms=1
            break
          fi
        fi
      done
      if [ "$active_gms" -eq 1 ]; then
        echo "GMS Processes  : Running"
      else
        echo "GMS Processes  : Suspended/Stopped"
      fi
    fi
    
    # Check GMS network block status
    GMS_UID=$( (cmd package list packages -U 2>/dev/null || pm list packages -U 2>/dev/null) | grep -E "^package:com.google.android.gms($|[[:space:]])" | grep -oE "uid:[0-9,]+" | cut -d':' -f2 | cut -d',' -f1 | tr -d '\r' )
    if [ -n "$GMS_UID" ] && iptables -C OUTPUT -m owner --uid-owner "$GMS_UID" -j DROP 2>/dev/null; then
      echo "Network Block  : Enabled (Blocked)"
    else
      echo "Network Block  : Disabled (Allowed)"
    fi
    echo "============================================="
    ;;
esac
